# .dockerignore — arquivos excluídos da imagem Docker

# Ambiente virtual e cache Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Arquivos sensíveis — NUNCA entram na imagem
.env

# Cache do mapa OSM — gerado em runtime
.map_cache/

# Relatórios gerados — não fazem parte da imagem
relatorios/

# Ferramentas de desenvolvimento
.git/
.gitignore
*.md

# Pygame — não usado na API
# (não instalar evita dependência de display gráfico)
draw_functions.py
map_background.py
tsp.py

# IDE
.vscode/
.idea/
*.swp
